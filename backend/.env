# Server Configuration
PORT=5000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3307
DB_NAME=youtube_summary_nodejs
DB_USER=yt_summary
DB_PASSWORD=summary
DB_DIALECT=mysql

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# YouTube API (Optional)
# YOUTUBE_API_KEY=

# Ollama Configuration
OLLAMA_HOST=http://192.168.1.30:11434
# OLLAMA_HOST=https://yes-ollama.kubela.id
OLLAMA_MODEL=gemma-2-2b-it  # or mistral, codellama, gemma, etc.
OLLAMA_MODEL_SUMMARY= gemma-2-2b-it # llama3:8b # mistral:7b # gemma-2-2b-it  # Larger model for summaries
OLLAMA_MODEL_FAST=gemma-2-2b-it  # Smaller model for simple tasks
OLLAMA_TIMEOUT=300000  # 5 minutes timeout

# Optional: Fallback to cloud AI if Ollama fails
ENABLE_AI_FALLBACK=false
OPENAI_API_KEY=  # Optional fallback
GEMINI_API_KEY=   # Optional fallback

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# CORS
# CORS_ORIGIN=http://192.168.1.30:3000
CORS_ORIGIN=https://yes.kubela.id

# Session
SESSION_SECRET=your_session_secret